# Database
APP_DB_PATH=data/app.db

# Seed sample data on startup (true/false)
APP_SEED_DATA=true

# Logging: DEBUG | INFO | WARNING | ERROR
# Set DEBUG to enable EXPLAIN QUERY PLAN logging in EmployeeRepository
LOG_LEVEL=INFO

# Rate limiting
RATE_LIMIT_MAX_TRACKED_KEYS=200000
RATE_LIMIT_CLEANUP_INTERVAL_SECONDS=30
